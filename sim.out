:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5a3f27bfabe0 .scope module, "dmem_tb" "dmem_tb" 2 1;
 .timescale 0 0;
v0x5a3f27c0e590_0 .var "address", 31 0;
v0x5a3f27c0e670_0 .var "clk", 0 0;
v0x5a3f27c0e740_0 .var "mem_write", 0 0;
