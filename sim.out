v0x5a3f27c0e910_0 .var "write_data", 31 0;
S_0x5a3f27bfad70 .scope module, "dut" "dmem" 2 13, 3 1 0, S_0x5a3f27bfabe0;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "mem_write";
    .port_info 2 /INPUT 32 "address";
    .port_info 3 /INPUT 32 "write_data";
    .port_info 4 /OUTPUT 32 "read_data";
L_0x5a3f27c0ec40 .functor BUFZ 32, L_0x5a3f27c0ea00, C4<00000000000000000000000000000000>, C4<00000000000000000000000000000000>, C4<00000000000000000000000000000000>;
v0x5a3f27bfaf70_0 .net *"_ivl_0", 31 0, L_0x5a3f27c0ea00;  1 drivers
v0x5a3f27c0ded0_0 .net *"_ivl_3", 29 0, L_0x5a3f27c0eb00;  1 drivers
v0x5a3f27c0dfb0_0 .net "address", 31 0, v0x5a3f27c0e590_0;  1 drivers
v0x5a3f27c0e0a0_0 .net "clk", 0 0, v0x5a3f27c0e670_0;  1 drivers
v0x5a3f27c0e160_0 .net "mem_write", 0 0, v0x5a3f27c0e740_0;  1 drivers
v0x5a3f27c0e270 .array "memory", 255 0, 31 0;
v0x5a3f27c0e330_0 .net "read_data", 31 0, L_0x5a3f27c0ec40;  alias, 1 drivers
v0x5a3f27c0e410_0 .net "write_data", 31 0, v0x5a3f27c0e910_0;  1 drivers
E_0x5a3f27bc0b40 .event posedge, v0x5a3f27c0e0a0_0;
L_0x5a3f27c0ea00 .array/port v0x5a3f27c0e270, L_0x5a3f27c0eb00;
L_0x5a3f27c0eb00 .part v0x5a3f27c0e590_0, 2, 30;
    .scope S_0x5a3f27bfad70;
T_0 ;
    %wait E_0x5a3f27bc0b40;
    %load/vec4 v0x5a3f27c0e160_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %load/vec4 v0x5a3f27c0e410_0;
    %load/vec4 v0x5a3f27c0dfb0_0;
    %parti/s 30, 2, 3;
    %ix/vec4 3;
    %ix/load 4, 0, 0; Constant delay
    %assign/vec4/a/d v0x5a3f27c0e270, 0, 4;
T_0.0 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x5a3f27bfabe0;
T_1 ;
    %delay 5, 0;
    %load/vec4 v0x5a3f27c0e670_0;
    %inv;
    %store/vec4 v0x5a3f27c0e670_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x5a3f27bfabe0;
T_2 ;
    %vpi_call 2 25 "$dumpfile", "waveforms/dmem.vcd" {0 0 0};
    %vpi_call 2 26 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5a3f27bfabe0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5a3f27c0e670_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5a3f27c0e740_0, 0, 1;
    %pushi/vec4 4, 0, 32;
    %store/vec4 v0x5a3f27c0e590_0, 0, 32;
    %pushi/vec4 100, 0, 32;
    %store/vec4 v0x5a3f27c0e910_0, 0, 32;
    %delay 10, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5a3f27c0e740_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 42 "$finish" {0 0 0};
    %end;
    .thread T_2;
